{
  "version": "1.1",
  "enabled": true,
  "enforceAtStartup": false,
  "autoDelegate": {
    "enabled": true,
    "description": "When a coordinator role's tool call is blocked, automatically delegate to implementation role"
  },
  "roles": {
    "jarvis": {
      "allow": [
        "read",
        "memory_search",
        "memory_get",
        "sessions_spawn",
        "sessions_list",
        "sessions_history",
        "session_status",
        "message",
        "tts"
      ]
    },
    "alex": {
      "allow": [
        "read",
        "write",
        "edit",
        "exec",
        "memory_search",
        "memory_get"
      ]
    },
    "scout": {
      "allow": [
        "read",
        "exec",
        "session_status",
        "sessions_list"
      ]
    }
  }
}
